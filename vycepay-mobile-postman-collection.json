            "url": "{{baseUrl}}/api/v1/activity/log",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"LOGIN\",\n  \"resourceType\": \"TRANSACTION\",\n  \"resourceId\": \"{{transactionId}}\",\n  \"ipAddress\": \"1.2.3.4\",\n  \"userAgent\": \"App/1.0\",\n  \"deviceId\": \"device-123\"\n}"
            }
          }
        },
        {
          "name": "25) List activity",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
