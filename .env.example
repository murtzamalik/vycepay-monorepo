# =============================================================================
# VycePay Deployment Environment
# =============================================================================
# Copy to .env and replace all CHANGE_ME / placeholder values before production.
#
# Server deployment (recommended for VPS):
#   cp .env.example .env
#   docker compose -f docker-compose.vycepay.server.yml up -d --build
#
# Other compose files also read this file automatically from the repo root.
# =============================================================================

# --- Runtime ---
# Use prod for production; dev allows local admin JWT fallback in some compose files.
SPRING_PROFILES_ACTIVE=prod

# --- Public host (used in comments / manual URL setup) ---
# Set to your server IP or domain, e.g. 203.0.113.10 or admin.vycepay.com
DEPLOY_PUBLIC_HOST=CHANGE_ME

# --- MySQL (multi-service compose: docker-compose.yml only) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=vycepay
MYSQL_USER=vycepay
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
MYSQL_HOST_PORT=3306

# --- Customer/mobile JWT (min 256-bit / 32+ bytes) ---
JWT_SECRET=CHANGE_ME_CUSTOMER_JWT_SECRET_MIN_32_BYTES

# --- Admin backoffice JWT (must differ from JWT_SECRET; min 32 bytes) ---
ADMIN_JWT_SECRET=CHANGE_ME_ADMIN_JWT_SECRET_MIN_32_BYTES
ADMIN_CORS_ORIGINS=http://localhost:3000,http://${DEPLOY_PUBLIC_HOST}:3000

# First super-admin (only created when admin_user table is empty). Remove after first login.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@vycepay.local
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_BOOTSTRAP_PASSWORD
ADMIN_BOOTSTRAP_FULL_NAME=Super Admin

# Admin portal URLs
# ADMIN_API_URL: internal Docker network URL (do not expose to browsers)
# NEXT_PUBLIC_ADMIN_API_URL: browser-visible admin API base URL
ADMIN_API_URL=http://vycepay:8090
NEXT_PUBLIC_ADMIN_API_URL=http://CHANGE_ME:8090

# --- Choice Bank BaaS ---
CHOICE_BANK_BASE_URL=https://baas-pilot.choicebankapi.com
CHOICE_BANK_SENDER_ID=
CHOICE_BANK_PRIVATE_KEY=

# --- Callback webhook ---
# Set true in production once Choice Bank signature verification is configured.
CALLBACK_VERIFY_SIGNATURE=true

# --- Optional admin tuning ---
# ADMIN_JWT_EXPIRATION_MS=900000
# ADMIN_LOGIN_MAX_ATTEMPTS=5
# ADMIN_LOCKOUT_MINUTES=15
# ADMIN_EXPORT_MAX_ROWS=10000
# ADMIN_RATE_LIMIT_LOGIN_LIMIT=5
# ADMIN_RATE_LIMIT_RESET_LIMIT=3
# ADMIN_RATE_LIMIT_EXPORT_LIMIT=5
# ADMIN_RATE_LIMIT_MUTATION_LIMIT=30

# --- Optional auth tuning ---
# JWT_EXPIRY_MINUTES=10
# OTP_LENGTH=6
# OTP_EXPIRY_MINUTES=5
